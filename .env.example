# Websites are checked with HTTP GET requests.
WEBSITES=https://edgelearning.co/,https://sircletech.in/,https://finawiz.com/

# Runs at 09:00 and 15:00 every day in IST.
SCHEDULE_CRON=0 9,15 * * *
SCHEDULE_TIMEZONE=Asia/Kolkata

# Health-check behavior.
REQUEST_TIMEOUT_MS=15000
RETRY_COUNT=3
RETRY_INTERVAL_MS=30000
RUN_ON_START=false

# Runtime files.
LOG_FILE=logs/checks.jsonl
SUMMARY_FILE=logs/summaries.jsonl
STATE_FILE=state/outages.json

# Email alerts.
# Set ALERTS_ENABLED=false for local dry runs without SMTP.
ALERTS_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=monitor@example.com
SMTP_PASS=replace-with-app-password
EMAIL_FROM="Website Monitor <monitor@example.com>"
EMAIL_TO=you@example.com
